{
  "identifier": "datadog_mcp",
  "title": "Datadog",
  "description": "Query logs, metrics, and traces from Datadog for incident investigation",
  "icon": "Datadog",
  "url": "https://your-mcp-proxy.com/datadog",
  "headers": {
    "Authorization": "Bearer {{secrets.DATADOG_API_KEY}}"
  },
  "allowed_tools": [
    {
      "name": "search_logs",
      "description": "Search logs by service, time range, and query",
      "parameters": {
        "service": "string - Service name to filter logs",
        "query": "string - Datadog log query syntax",
        "timeframe": "string - Time range (e.g., '1h', '24h', '7d')",
        "limit": "number - Max results to return (default 100)"
      },
      "example": "search_logs(service='payments', query='status:error', timeframe='1h')"
    },
    {
      "name": "get_metrics",
      "description": "Get metric timeseries data",
      "parameters": {
        "metric": "string - Metric name (e.g., 'trace.http.request.duration')",
        "service": "string - Service to filter by",
        "timeframe": "string - Time range",
        "aggregation": "string - avg, max, min, sum (default avg)"
      },
      "example": "get_metrics(metric='trace.http.request.duration.p99', service='payments', timeframe='1h')"
    },
    {
      "name": "get_monitors",
      "description": "Get monitor status and alerts",
      "parameters": {
        "service": "string - Filter by service tag",
        "status": "string - Filter by status (Alert, Warn, OK, No Data)"
      },
      "example": "get_monitors(service='payments', status='Alert')"
    },
    {
      "name": "get_traces",
      "description": "Get APM traces for a service",
      "parameters": {
        "service": "string - Service name",
        "operation": "string - Optional operation/endpoint filter",
        "timeframe": "string - Time range",
        "min_duration": "string - Filter slow traces (e.g., '1s')"
      },
      "example": "get_traces(service='payments', min_duration='2s', timeframe='1h')"
    },
    {
      "name": "get_error_tracking",
      "description": "Get error tracking issues",
      "parameters": {
        "service": "string - Service name",
        "timeframe": "string - Time range",
        "status": "string - new, reviewed, ignored"
      },
      "example": "get_error_tracking(service='payments', status='new', timeframe='24h')"
    }
  ],
  "rate_limit": {
    "requests_per_minute": 30,
    "burst": 10
  },
  "notes": "Requires Datadog API key with logs_read, metrics_read, and apm_read scopes"
}
